# Automatos Monitoring Stack — Environment Variables
# Copy to .env and fill in values

# ─────────────────────────────────────────────
# Grafana
# ─────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_PORT=3030
GRAFANA_ROOT_URL=http://localhost:3030

# ─────────────────────────────────────────────
# PostgreSQL Exporter
# ─────────────────────────────────────────────
POSTGRES_CONNECTION_STRING=postgresql://postgres:your_password@postgres:5432/orchestrator_db?sslmode=disable

# ─────────────────────────────────────────────
# Redis Exporter
# ─────────────────────────────────────────────
REDIS_PASSWORD=your_redis_password

# ─────────────────────────────────────────────
# Log Relay
# ─────────────────────────────────────────────
LOG_RELAY_SECRET=your_shared_secret
LOG_RELAY_PORT=3200
ENVIRONMENT=development

# ─────────────────────────────────────────────
# Prometheus
# ─────────────────────────────────────────────
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d

# ─────────────────────────────────────────────
# Loki
# ─────────────────────────────────────────────
LOKI_PORT=3100

# ─────────────────────────────────────────────
# AlertManager
# ─────────────────────────────────────────────
ALERTMANAGER_PORT=9093
