{
  "uid": "error-tracking",
  "title": "Error Tracking & Debugging",
  "description": "Error fingerprints, stack traces, workspace-scoped debugging, and error trends",
  "tags": ["automatos", "errors", "debugging"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(service)",
        "current": {},
        "hide": 0,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "error_type",
        "label": "Error Type",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(error_type)",
        "current": {},
        "hide": 0,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "workspace_id",
        "label": "Workspace ID",
        "type": "textbox",
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0
      },
      {
        "name": "fingerprint",
        "label": "Error Fingerprint",
        "type": "textbox",
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0
      },
      {
        "name": "request_id",
        "label": "Request ID",
        "type": "textbox",
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "title": "Error Overview",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1
    },
    {
      "id": 2,
      "title": "Total Errors (6h)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "textMode": "value", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service=~\"$service\", level=~\"error|critical\"} [6h]))"
        }
      ]
    },
    {
      "id": 3,
      "title": "Critical Errors (6h)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "textMode": "value", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service=~\"$service\", level=\"critical\"} [6h]))"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error Rate (5m window)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "noValue": "0%"
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service=~\"$service\", level=~\"error|critical\"} [5m])) / (sum(count_over_time({service=~\"$service\"} [5m])) > 0)"
        }
      ]
    },
    {
      "id": 5,
      "title": "Unique Error Types (6h)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "textMode": "value", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(count by (error_type) (count_over_time({service=~\"$service\", level=\"error\", error_type=~\".+\"} [6h])))"
        }
      ]
    },
    {
      "id": 6,
      "title": "Errors by Type",
      "type": "piechart",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "hidden" },
        "tooltip": { "mode": "multi" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (error_type) (count_over_time({service=~\"$service\", level=\"error\", error_type=~\"$error_type\"} [6h]))",
          "legendFormat": "{{ error_type }}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Errors by Module",
      "type": "piechart",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "hidden" },
        "tooltip": { "mode": "multi" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (module) (count_over_time({service=~\"$service\", level=\"error\", module=~\".+\"} [6h]))",
          "legendFormat": "{{ module }}"
        }
      ]
    },
    {
      "title": "Error Trends",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10
    },
    {
      "id": 11,
      "title": "Error Rate Over Time",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "drawStyle": "line",
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (count_over_time({service=~\"$service\", level=~\"error|critical\"} [$__interval]))",
          "legendFormat": "{{ service }}"
        }
      ]
    },
    {
      "id": 12,
      "title": "Errors by Error Type Over Time",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 30,
            "stacking": { "group": "A", "mode": "normal" },
            "drawStyle": "bars"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (error_type) (count_over_time({service=~\"$service\", level=\"error\", error_type=~\"$error_type\"} [$__interval]))",
          "legendFormat": "{{ error_type }}"
        }
      ]
    },
    {
      "title": "Workspace Debugging",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 20
    },
    {
      "id": 21,
      "title": "Workspace Errors",
      "description": "Enter a Workspace ID above to filter. Shows all errors for that workspace.",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 14 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=~\"$service\", level=~\"error|warning|critical\"} | json | ctx_ws=~\".*$workspace_id.*\" | err_fp=~\".*$fingerprint.*\"",
          "maxLines": 200
        }
      ]
    },
    {
      "title": "Request Tracing",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 30
    },
    {
      "id": 31,
      "title": "Request Trace",
      "description": "Enter a Request ID above to see the full request lifecycle across all services.",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 25 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Ascending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=~\".+\"} |~ \"$request_id\"",
          "maxLines": 200
        }
      ]
    },
    {
      "title": "All Error Logs",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 40
    },
    {
      "id": 41,
      "title": "Error Log Stream",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 36 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=~\"$service\", level=~\"error|critical\", error_type=~\"$error_type\"}",
          "maxLines": 500
        }
      ]
    }
  ]
}
