  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": true,
          "text": "Prometheus",
          "value": "prometheus"
        },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false
      }
    ]
  },
  "panels": [
    {
      "title": "Phase 2 Notice",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": []
    },
    {
      "id": 2,
      "title": "Dashboard Status",
      "type": "text",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 1 },
      "options": {
        "mode": "markdown",
        "content": "## Placeholder Dashboard\n\nThis dashboard requires custom Prometheus metrics from the FastAPI `/metrics` endpoint, which will be implemented in **Phase 2**.\n\nThe agent heartbeat system performs periodic autonomous checks. Once the `/metrics` endpoint exposes `automatos_agent_*` metrics, these panels will populate automatically.\n\n**Required metrics:** `automatos_agent_heartbeat_total`, `automatos_agent_heartbeat_duration_seconds`, `automatos_agent_heartbeat_errors_total`, `automatos_agent_token_usage_total`",
        "code": { "language": "plaintext", "showLineNumbers": false, "showMiniMap": false }
      }
    },
    {
      "title": "Heartbeat Metrics",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 3,
      "panels": []
    },
    {
      "id": 4,
      "title": "Heartbeat Success Rate",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          },
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "noValue": "Awaiting Phase 2",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1 - (rate(automatos_agent_heartbeat_errors_total[5m]) / rate(automatos_agent_heartbeat_total[5m]))",
          "legendFormat": "",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Heartbeat Execution Count",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short",
          "noValue": "Awaiting Phase 2",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "automatos_agent_heartbeat_total",
          "legendFormat": "",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "title": "Avg Heartbeat Duration",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          },
          "unit": "s",
          "noValue": "Awaiting Phase 2",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(automatos_agent_heartbeat_duration_seconds_sum[5m]) / rate(automatos_agent_heartbeat_duration_seconds_count[5m])",
          "legendFormat": "",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "title": "Token Usage",
      "type": "stat",
